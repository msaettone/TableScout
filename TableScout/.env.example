# Neon Postgres — pooled connection for normal app queries
DATABASE_URL=
# Neon Postgres — unpooled, required for `prisma migrate deploy`
DIRECT_URL=

# Resy's public web API key (not your personal session token — that's
# connected per-user in Settings, not set here)
RESY_API_KEY=

# Self-generated: `openssl rand -hex 32`. AES-256-GCM key encrypting each
# user's Resy session token at rest.
RESY_TOKEN_ENC_KEY=

# Self-generated: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Firebase Admin SDK (server-only) — Project Settings > Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase client config (safe to expose) — Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Self-generated random secret. cron-job.org sends this as
# `Authorization: Bearer <value>` when it hits /api/cron/tick in production.
CRON_SECRET=
